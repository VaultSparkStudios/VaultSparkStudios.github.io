{
  "name": "vaultsparkstudios.github.io",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "node scripts/build-shell-assets.mjs && node scripts/generate-public-intelligence.mjs",
    "build:check": "node scripts/build-shell-assets.mjs --check && node scripts/generate-public-intelligence.mjs --check && node scripts/lint-repo.mjs && node scripts/validate-contracts.mjs --check",
    "lint:repo": "node scripts/lint-repo.mjs",
    "lint:repo:staged": "node scripts/lint-repo.mjs --staged",
    "test": "npx playwright test",
    "test:a11y": "npx playwright test tests/accessibility.spec.js",
    "verify:local": "node scripts/run-local-browser-verify.mjs",
    "verify:local:extended": "node scripts/run-local-browser-verify.mjs --tier extended",
    "verify:live-browser": "node scripts/run-live-browser-verify.mjs",
    "verify:confidence": "node scripts/release-confidence.mjs",
    "verify:headers": "node scripts/verify-live-headers.mjs",
    "startup:snapshot": "node scripts/startup-snapshot.mjs",
    "genius:list": "node scripts/generate-genius-list.mjs",
    "smoke:http": "node scripts/smoke-http.mjs",
    "validate:contracts": "node scripts/validate-contracts.mjs",
    "provision:test-accounts": "node scripts/provision-vault-test-accounts.mjs"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@playwright/test": "^1.49.0",
    "sharp": "^0.34.5"
  }
}
